<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.cooking.star.admin.AdminMapper">
  
  <select id="getMemberList" resultMap="adminMemberResult">
  SELECT *
  FROM "COOK_MEMBER" m
  LEFT JOIN "COOK_MEMBER_ROLE" mr USING ("USERNAME")
  LEFT JOIN "COOK_ROLE" r USING ("ROLE_NUM")
  ORDER BY "USERNAME"
</select>

<resultMap type="MemberDTO" id="adminMemberResult">
  <id column="USERNAME" property="username"/>
  <result column="PASSWORD" property="password"/>
  <result column="NAME" property="name"/>
  <result column="EMAIL" property="email"/>
  <result column="ENABLED" property="enabled"/>
  <result column="CREDENTIALS_NON_EXPIRED" property="credentialsNonExpired"/>
  <result column="ACCOUNT_NON_LOCKED" property="accountNonLocked"/>
  <result column="ACCOUNT_NON_EXPIRED" property="accountNonExpired"/>

  <collection property="roles" javaType="java.util.List" ofType="RoleDTO">
    <id column="ROLE_NUM" property="roleNum"/>
    <result column="ROLE_NAME" property="roleName"/>
  </collection>
</resultMap>
  
  <select id="getRecipeList" resultType="MyRecipeDTO">
  SELECT * FROM "COOK_MYRECIPE"
  ORDER BY "RECIPE_NUM" DESC
  
  
  </select>
  
  <select id="getMemberCount" resultType="int">
  SELECT COUNT(*)
  FROM "COOK_MEMBER"
  
  </select>
  
  <select id="getRecipeCount" resultType="int">
  SELECT COUNT(*)
  FROM "COOK_MYRECIPE"
  </select>
  
  <resultMap type="RoleDTO" id="adminRoleResult">
    <id column="ROLE_NUM" property="roleNum"/>
    <result column="ROLE_NAME" property="roleName"/>
  </resultMap>
  
  <select id="getRoleList" resultMap="adminRoleResult">
  SELECT "ROLE_NUM", "ROLE_NAME"
  FROM "COOK_ROLE"
  ORDER BY "ROLE_NUM"
  </select>
  
  <update id="updateMemberRole">
  UPDATE "COOK_MEMBER_ROLE"
  SET "ROLE_NUM"=#{roleNum}
  WHERE "USERNAME"=#{username}
  </update>
  
  
  
  
  
  </mapper>
