<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
 <mapper namespace="com.cooking.star.member.MemberMapper">
 
 <insert id="join" parameterType="MemberDTO" >
 INSERT INTO "COOK_MEMBER"
 VALUES (#{username},#{password},#{name},#{email})
 
 
 </insert>
 
 <select id="login" parameterType="MemberDTO" resultMap="loginResult" >
 select * from "COOK_MEMBER" m
LEFT JOIN "COOK_PROFILE" p 
USING ("USERNAME")
INNER JOIN "COOK_MEMBER_ROLE"
USING ("USERNAME")
INNER JOIN "COOK_ROLE"
USING ("ROLE_NUM")
WHERE "USERNAME"=#{username}
 
 
 </select>

	<resultMap type="MemberDTO" id="loginResult">
		<id column="USERNAME" property="username" />
		<result column="PASSWORD" property="password" />
		<result column="NAME" property="name" />
		<result column="EMAIL" property="email" />
		<result column="ENABLED" property="enabled" />
		<result column="CREDENTIALS_NON_EXPIRED" property="credentialsNonExpired" />
		<result column="ACCOUNT_NON_LOCKED" property="accountNonLocked" />
		<result column="ACCOUNT_NON_EXPIRED" property="accountNonExpired" />
	
	<association property="profileDTO" javaType="ProfileDTO">
		<id column="FILE_NUM" property="fileNum"/>
		<result column="FILE_NAME" property="fileName"/>
		<result column="ORI_NAME" property="oriName"/>
		<result column="USERNAME" property="username"/>
	</association>
	
	<collection property="roles" javaType="java.util.List" ofType="RoleDTO">
		<id column="ROLE_NUM" property="roleNum"/>
		<result column="ROLE_NAME" property="roleName"/>
	
	</collection>
	



	</resultMap>
 
 
 
 <insert id="addProfile" parameterType="ProfileDTO">
 INSERT INTO "COOK_PROFILE" ("FILE_NAME","ORI_NAME","USERNAME")
 VALUES (#{fileName},#{oriName},#{username})
 
 
 </insert>
 
 
 <select id="myProfile" parameterType="MemberDTO" resultMap="loginResult">
 SELECT * FROM "COOK_MEMBER" m
 LEFT JOIN "COOK_PROFILE" p 
 USING ("USERNAME")
 WHERE "USERNAME"=#{username}
 </select>
 
 <update id="myProfileUpdate" parameterType="MemberDTO">
 UPDATE "COOK_MEMBER"
 SET "NAME"=#{name}
 , "EMAIL"=#{email}
 WHERE "USERNAME"=#{username}
 </update>
 <update id="updateProfile" parameterType="ProfileDTO">
    UPDATE "COOK_PROFILE"
    SET "FILE_NAME" = #{fileName},
        "ORI_NAME" = #{oriName}
    WHERE "USERNAME" = #{username}
</update>
<delete id="deleteProfile" parameterType="String">
    DELETE FROM "COOK_PROFILE"
    WHERE "USERNAME" = #{username}
</delete>
 
 <select id="user" parameterType="MemberDTO" resultType="MyRecipeDTO">
 
 SELECT * FROM "COOK_MEMBER" m 
 LEFT JOIN "COOK_MYRECIPE" r
USING ("USERNAME")
WHERE "USERNAME"=#{username} 
 
 </select>
 
 <resultMap type="MemberDTO" id="userResult" >
 
 <id column="USERNAME" property="username" />
		<result column="PASSWORD" property="password" />
		<result column="NAME" property="name" />
		<result column="EMAIL" property="email" />
		<result column="ENABLED" property="enabled" />
		<result column="CREDENTIALS_NON_EXPIRED" property="credentialsNonExpired" />
		<result column="ACCOUNT_NON_LOCKED" property="accountNonLocked" />
		<result column="ACCOUNT_NON_EXPIRED" property="accountNonExpired" />
 
 <collection property="myRecipeList" javaType="java.util.List" ofType="MyRecipeDTO">
 
 	<id column="RECIPE_NUM" property="recipeNum"/>
	<result column="USERNAME" property="username"/>
	<result column="RECIPE_TITLE" property="recipeTitle"/>
	<result column="RECIPE_CONTENTS" property="recipeContents"/>
	<result column="RECIPE_GOOD" property="recipeGood"/>
	<result column="RECIPE_HIT" property="recipeHit"/>
	<result column="RECIPE_DATE" property="recipeDate"/>
 
 </collection>
 </resultMap>
 
 <!-- 내가(로그인한 유저) 팔로잉 하고 있는 유저 리스트  -->
 <select id="followingList" parameterType="String" resultType="FollowDTO">
   SELECT
        "FOLLOWING_USER",
        "FOLLOWER_USER"
    FROM "COOK_FOLLOW"
    WHERE "FOLLOWER_USER" = #{username}
 </select>
 <!-- 나를(로그인한 유저) 팔로잉 하는 유저 리스트-->
 <select id="followerList" parameterType="String" resultType="FollowDTO">
     SELECT
        "FOLLOWING_USER",
        "FOLLOWER_USER"
    FROM "COOK_FOLLOW"
    WHERE "FOLLOWING_USER" = #{username}
</select>
<!--  로그인한 사람을 팔로잉 한 사람 수 -->
 <select id="followerCount" parameterType="String" resultType="int">
    SELECT COUNT(*)
    FROM "COOK_FOLLOW"
    WHERE "FOLLOWING_USER" = #{username}
</select>
<!--로그인한 사람이 팔로잉 한 사람 수  -->
 <select id="followingCount" parameterType="String" resultType="int">
    SELECT COUNT(*)
    FROM "COOK_FOLLOW"
    WHERE "FOLLOWER_USER" = #{username}
</select>
 
 
 </mapper>