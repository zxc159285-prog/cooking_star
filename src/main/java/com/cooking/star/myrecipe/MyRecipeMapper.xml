  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.cooking.star.myrecipe.MyRecipeMapper">
  
  <insert id="create" parameterType="MyRecipeDTO">
  INSERT INTO "COOK_MYRECIPE"
